<Window x:Class="CyberSecurityChatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot"
        Height="700"
        Width="1100"
        Background="#0B1F3A"
        WindowStartupLocation="CenterScreen">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0"
                Background="#09162B">

            <StackPanel Margin="10">

                <TextBlock Text="🛡 DASHBOARD"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#FFD700"
                           Margin="10"/>

                <Button x:Name="btnChat"
                        Content="💬 Chat"
                        Height="50"
                        Margin="5"
                        Click="btnChat_Click"/>

                <Button x:Name="btnTasks"
                        Content="📝 Tasks"
                        Height="50"
                        Margin="5"
                        Click="btnTasks_Click"/>

                <Button x:Name="btnQuiz"
                        Content="🧠 Quiz"
                        Height="50"
                        Margin="5"
                        Click="btnQuiz_Click"/>

                <Button x:Name="btnLog"
                        Content="📋 Activity Log"
                        Height="50"
                        Margin="5"
                        Click="btnLog_Click"/>

            </StackPanel>

        </Border>

        <!-- MAIN AREA -->
        <Grid Grid.Column="1">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0"
                    Background="#D4AF37"
                    Padding="15">

                <TextBlock Text="CYBERSECURITY AWARENESS BOT"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#0B1F3A"
                           HorizontalAlignment="Center"/>

            </Border>

            <!-- CONTENT AREA -->
            <Grid Grid.Row="1" Margin="10">

                <!-- CHAT PANEL -->
                <Border x:Name="ChatPanel"
                        Background="White"
                        CornerRadius="10">

                    <TextBox x:Name="txtChat"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             FontSize="16"
                             BorderThickness="0"
                             Margin="10"/>

                </Border>

                <!-- TASK PANEL -->
                <Border x:Name="TaskPanel"
                        Background="White"
                        CornerRadius="10"
                        Visibility="Collapsed">

                    <Grid Margin="15">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Task Manager"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Margin="0,0,0,15"/>

                        <StackPanel Grid.Row="1"
                                    Orientation="Horizontal"
                                    Margin="0,0,0,15">

                            <TextBox x:Name="txtTaskName"
                                     Width="250"
                                     Height="35"
                                     Margin="0,0,10,0"/>

                            <Button x:Name="btnAddTask"
                                    Content="Add Task"
                                    Width="120"
                                    Height="35"
                                    Margin="0,0,10,0"
                                    Click="btnAddTask_Click"/>

                            <Button x:Name="btnCompleteTask"
                                    Content="Complete"
                                    Width="120"
                                    Height="35"
                                    Margin="0,0,10,0"
                                    Click="btnCompleteTask_Click"/>

                            <Button x:Name="btnDeleteTask"
                                    Content="Delete"
                                    Width="120"
                                    Height="35"
                                    Click="btnDeleteTask_Click"/>

                        </StackPanel>

                        <ListBox x:Name="lstTasks"
                                 Grid.Row="2"/>

                    </Grid>

                </Border>

                <!-- QUIZ PANEL -->
                <Border x:Name="QuizPanel"
                        Background="White"
                        CornerRadius="10"
                        Visibility="Collapsed">

                    <StackPanel Margin="20">

                        <TextBlock Text="Cybersecurity Quiz"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Margin="0,0,0,20"/>

                        <TextBlock x:Name="txtQuizQuestion"
                                   FontSize="18"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,20"/>

                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="btnTrue"
        Content="TRUE"
        Width="120"
        Height="40"
        Margin="0,0,10,0"
        Click="btnTrue_Click"/>

                            <Button x:Name="btnFalse"
        Content="FALSE"
        Width="120"
        Height="40"
        Click="btnFalse_Click"/>

                        </StackPanel>

                    </StackPanel>

                </Border>

                <!-- LOG PANEL -->
                <Border x:Name="LogPanel"
                        Background="White"
                        CornerRadius="10"
                        Visibility="Collapsed">

                    <StackPanel Margin="20">

                        <TextBlock Text="Activity Log"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Margin="0,0,0,15"/>

                        <ListBox x:Name="lstLog"/>

                    </StackPanel>

                </Border>

            </Grid>

            <!-- INPUT AREA -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        Margin="10">

                <TextBox x:Name="txtUserInput"
                         Width="650"
                         Height="40"
                         Margin="0,0,10,0"/>

                <Button x:Name="btnSend"
                        Content="SEND"
                        Width="150"
                        Height="40"
                        Click="btnSend_Click"/>

            </StackPanel>

        </Grid>

    </Grid>

</Window>