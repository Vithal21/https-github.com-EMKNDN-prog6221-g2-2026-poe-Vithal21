<Window x:Class="CyberSecurityChatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot"
        Height="600"
        Width="900"
        Background="#1E1E1E">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Background="#007ACC"
                CornerRadius="10"
                Padding="15"
                Margin="0,0,0,10">

            <StackPanel>

                <TextBlock Text="CYBERSECURITY AWARENESS BOT"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Stay Safe Online"
                           FontSize="16"
                           Foreground="White"
                           HorizontalAlignment="Center"/>

            </StackPanel>

        </Border>

        <!-- CHAT AREA -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">

            <TextBox x:Name="txtChat"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     FontSize="16"
                     Background="#2D2D30"
                     Foreground="White"
                     BorderThickness="0"
                     AcceptsReturn="True"/>

        </ScrollViewer>

        <!-- INPUT AREA -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Margin="0,10,0,0">

            <TextBox x:Name="txtUserInput"
                     Width="700"
                     Height="40"
                     FontSize="16"
                     Margin="0,0,10,0"/>

            <Button x:Name="btnSend"
                    Content="Send"
                    Width="150"
                    Height="40"
                    Background="#007ACC"
                    Foreground="White"
                    FontSize="16"
                    Click="btnSend_Click"/>

        </StackPanel>

    </Grid>
</Window>