<Window x:Class="CyberSecurityChatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot"
        Height="650"
        Width="950"
        Background="#0B1F3A"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="#D4AF37"
                CornerRadius="15"
                Padding="20"
                Margin="0,0,0,15">

            <StackPanel>

                <TextBlock Text="🔐 CYBERSECURITY AWARENESS BOT 🔐"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="#0B1F3A"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <TextBlock Text="Stay Safe • Stay Smart • Stay Protected"
                           FontSize="18"
                           FontStyle="Italic"
                           Foreground="#0B1F3A"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="
═══════════════════════════════════════
        CYBER SAFE PROTECTION SYSTEM
═══════════════════════════════════════
"
                           FontSize="16"
                           Foreground="#0B1F3A"
                           HorizontalAlignment="Center"
                           Margin="0,15,0,0"/>

            </StackPanel>

        </Border>

        <!-- CHAT AREA -->
        <Border Grid.Row="1"
                Background="#13294B"
                CornerRadius="15"
                Padding="10">

            <ScrollViewer VerticalScrollBarVisibility="Auto">

                <TextBox x:Name="txtChat"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         FontSize="17"
                         FontFamily="Consolas"
                         Background="#13294B"
                         Foreground="#FFD700"
                         BorderThickness="0"
                         VerticalScrollBarVisibility="Auto"
                         Padding="10"/>

            </ScrollViewer>

        </Border>

        <!-- INPUT SECTION -->
        <Border Grid.Row="2"
                Background="#D4AF37"
                CornerRadius="15"
                Padding="15"
                Margin="0,15,0,0">

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">

                <TextBox x:Name="txtUserInput"
                         Width="650"
                         Height="45"
                         FontSize="16"
                         FontFamily="Segoe UI"
                         Background="White"
                         Foreground="#0B1F3A"
                         BorderBrush="#0B1F3A"
                         BorderThickness="2"
                         Padding="10"
                         Margin="0,0,15,0"/>

                <Button x:Name="btnSend"
                        Content="SEND"
                        Width="180"
                        Height="45"
                        FontSize="18"
                        FontWeight="Bold"
                        Background="#0B1F3A"
                        Foreground="#FFD700"
                        BorderBrush="#FFD700"
                        BorderThickness="2"
                        Cursor="Hand"
                        Click="btnSend_Click"/>

            </StackPanel>

        </Border>

    </Grid>
</Window>